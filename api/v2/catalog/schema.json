{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Numbers API V2 Catalog Schema",
  "type": "object",
  "required": [
    "schema",
    "generated_at",
    "games"
  ],
  "properties": {
    "schema": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "games": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "api_path"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "api_path": {
            "type": "string"
          }
        }
      }
    }
  }
}
