{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Numbers API V2 Catalog Schema",
  "type": "object",
  "required": [
    "schema",
    "generated_at",
    "games"
  ],
  "properties": {
    "schema": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "games": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "display_name",
          "app_id",
          "app_display_name",
          "number_count",
          "min_value",
          "max_value",
          "allow_duplicates",
          "has_bonus",
          "api",
          "prediction"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "app_id": {
            "type": "string"
          },
          "app_display_name": {
            "type": "string"
          },
          "number_count": {
            "type": "integer"
          },
          "min_value": {
            "type": "integer"
          },
          "max_value": {
            "type": "integer"
          },
          "allow_duplicates": {
            "type": "boolean"
          },
          "has_bonus": {
            "type": "boolean"
          },
          "api_path": {
            "type": "string"
          },
          "api": {
            "type": "object",
            "required": [
              "namespace",
              "version_path",
              "latest_path",
              "draws_full_path"
            ],
            "properties": {
              "namespace": {
                "type": "string"
              },
              "version_path": {
                "type": "string"
              },
              "latest_path": {
                "type": "string"
              },
              "draws_full_path": {
                "type": "string"
              }
            }
          },
          "prediction": {
            "type": "object",
            "required": [
              "purchase_modes"
            ],
            "properties": {
              "purchase_modes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
